{{define "work_packet_sections"}}
<section class="panel">
  <div class="section-header" style="margin-top:0;">Scope</div>
  <ul>
    {{range .Scope}}<li>{{.}}</li>{{else}}<li style="color:var(--text-secondary);">None provided.</li>{{end}}
  </ul>
</section>

<section class="panel">
  <div class="section-header" style="margin-top:0;">Deliverables</div>
  <ul>
    {{range .Deliverables}}<li>{{.}}</li>{{else}}<li style="color:var(--text-secondary);">None provided.</li>{{end}}
  </ul>
</section>

<section class="panel">
  <div class="section-header" style="margin-top:0;">Acceptance Criteria</div>
  <ul>
    {{range .AcceptanceCriteria}}<li>{{.}}</li>{{else}}<li style="color:var(--text-secondary);">None provided.</li>{{end}}
  </ul>
</section>

<section class="panel">
  <div class="section-header" style="margin-top:0;">Reward / Quote Model</div>
  <p style="margin:0;">{{if .RewardModel}}{{.RewardModel}}{{else}}<span style="color:var(--text-secondary);">Not specified.</span>{{end}}</p>
</section>
{{end}}
