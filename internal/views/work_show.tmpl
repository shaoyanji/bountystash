{{define "title"}}Work {{.ID}} | Bountystash{{end}}

{{define "content"}}
<section class="hero panel">
  <h1>{{.Packet.Title}}</h1>
  <p>Persisted immutable work packet version with exact and quotient provenance hashes.</p>
</section>

<section class="panel">
  <h2>Packet Metadata</h2>
  <div class="meta-grid">
    <div class="meta-cell"><strong>Work ID</strong>{{.ID}}</div>
    <div class="meta-cell"><strong>Status</strong>{{.Status}}</div>
    <div class="meta-cell"><strong>Kind</strong>{{.Packet.Kind}}</div>
    <div class="meta-cell"><strong>Visibility</strong>{{.Packet.Visibility}}</div>
    <div class="meta-cell"><strong>Version</strong>{{.Version}}</div>
    <div class="meta-cell"><strong>Created</strong>{{.CreatedAt.Format "2006-01-02 15:04:05 MST"}}</div>
  </div>
</section>

<section class="panel">
  <h2>Provenance</h2>
  <div class="meta-grid">
    <div class="meta-cell"><strong>Exact Hash</strong><code>{{.ExactHash}}</code></div>
    <div class="meta-cell"><strong>Quotient Hash</strong><code>{{.QuotientHash}}</code></div>
  </div>
</section>

{{template "work_packet_sections" .Packet}}
{{end}}
