{{define "layout"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{block "title" .}}Bountystash{{end}}</title>
  <style>
    :root {
      --bg: #f6f8fb;
      --ink: #14263a;
      --muted: #4d6072;
      --panel: #ffffff;
      --accent: #0f5c6f;
      --accent-soft: #ebf3f5;
      --border: #d6e0ea;
      --error: #a61e4d;
      --error-soft: #fff0f6;
      --subtle: #eef2f7;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, Georgia, serif;
      background:
        radial-gradient(circle at 12% -10%, rgba(15, 92, 111, 0.08), transparent 35%),
        radial-gradient(circle at 88% 0%, rgba(20, 38, 58, 0.08), transparent 28%),
        var(--bg);
      color: var(--ink);
      line-height: 1.55;
    }
    .shell {
      width: min(1060px, 100%);
      margin: 0 auto;
      padding: 24px 24px 32px;
    }
    .topnav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 24px;
      padding: 14px 16px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.88);
      backdrop-filter: blur(2px);
    }
    .brand {
      font-size: 1.02rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      text-decoration: none;
      color: var(--ink);
    }
    .nav-links {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
    }
    .nav-links a {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      font-size: 0.95rem;
    }
    .nav-links a:hover { border-color: var(--accent); }
    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 22px;
      margin-bottom: 18px;
      box-shadow: 0 8px 24px rgba(20, 38, 58, 0.06);
    }
    .error-panel {
      border-color: #f4c2d7;
      background: var(--error-soft);
      color: var(--error);
    }
    h1, h2, h3 {
      margin: 0 0 12px;
      line-height: 1.15;
      letter-spacing: 0.01em;
    }
    p { margin: 0 0 14px; color: var(--muted); }
    h2 {
      font-size: 1.35rem;
    }
    h3 {
      font-size: 1.1rem;
    }
    .hero h1 {
      font-size: clamp(2.1rem, 5vw, 3.2rem);
      margin-bottom: 14px;
    }
    .hero p {
      font-size: 1.07rem;
      max-width: 70ch;
    }
    .kicker {
      display: inline-block;
      margin-bottom: 10px;
      padding: 4px 10px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent);
      font-size: 0.82rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .grid {
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    }
    .step-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: 12px;
      margin-top: 14px;
    }
    .step {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--subtle);
      padding: 12px;
    }
    .step strong {
      display: inline-block;
      margin-bottom: 6px;
    }
    .card {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--panel);
      padding: 14px;
    }
    .card p:last-child { margin-bottom: 0; }
    .card h3 a,
    .text-link {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid transparent;
    }
    .card h3 a:hover,
    .text-link:hover {
      border-color: var(--accent);
    }
    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 10px;
    }
    .chip {
      display: inline-block;
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 2px 9px;
      font-size: 0.82rem;
      color: var(--muted);
      background: var(--subtle);
    }
    .cta-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      margin-top: 10px;
    }
    .button-link {
      display: inline-block;
      background: var(--accent);
      border: 1px solid var(--accent);
      color: #fff;
      text-decoration: none;
      border-radius: 8px;
      padding: 8px 14px;
      font-size: 0.95rem;
    }
    .button-link:hover {
      filter: brightness(0.95);
    }
    .activity-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 10px;
    }
    .activity-item {
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fbfcfe;
      padding: 10px 12px;
    }
    .activity-item p {
      margin: 0;
      color: var(--muted);
      font-size: 0.93rem;
    }
    .activity-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: baseline;
      margin-bottom: 4px;
    }
    .activity-head strong {
      color: var(--ink);
      font-size: 0.96rem;
    }
    .activity-head time {
      color: var(--muted);
      font-size: 0.86rem;
      white-space: nowrap;
    }
    .intake-form {
      display: grid;
      gap: 12px;
    }
    label {
      display: grid;
      gap: 6px;
      font-size: 0.95rem;
    }
    input, select, textarea, button {
      font: inherit;
      color: var(--ink);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 12px;
      background: #fff;
    }
    textarea {
      min-height: 88px;
      resize: vertical;
    }
    button {
      width: fit-content;
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
      cursor: pointer;
      padding: 9px 16px;
    }
    button:hover { filter: brightness(0.94); }
    ul {
      margin: 8px 0 0;
      padding-left: 20px;
    }
    .inline-list {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .inline-list a, .queue-title a {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid transparent;
    }
    .inline-list a:hover, .queue-title a:hover { border-color: var(--accent); }
    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 8px;
      font-size: 0.92rem;
    }
    .meta-grid .meta-cell {
      background: var(--accent-soft);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 8px 10px;
    }
    .meta-cell strong {
      display: block;
      font-size: 0.8rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .hint {
      font-size: 0.92rem;
      margin: 0;
    }
    .footer {
      margin-top: 22px;
      color: var(--muted);
      font-size: 0.9rem;
      text-align: center;
      padding: 10px 8px;
    }
    .queue {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.95rem;
    }
    .queue th, .queue td {
      border-bottom: 1px solid var(--border);
      text-align: left;
      padding: 8px 6px;
      vertical-align: top;
    }
    .queue thead th {
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      color: var(--muted);
    }
    @media (max-width: 760px) {
      .topnav {
        align-items: flex-start;
      }
      .activity-head {
        flex-direction: column;
        gap: 4px;
      }
    }
    @media (max-width: 640px) {
      .shell { padding: 14px; }
      .panel { padding: 16px; }
    }
  </style>
</head>
<body>
  <main class="shell">
    <nav class="topnav">
      <a class="brand" href="/">Bountystash</a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/examples/auth-loop">Examples</a>
        <a href="/review">Review</a>
        <a href="/history">History</a>
        <a href="/.well-known/bountystash-manifest">Manifest / API</a>
        <a href="/?format=text">TUI Text View</a>
      </div>
    </nav>
    {{block "content" .}}{{end}}
    <footer class="footer">
      Bountystash keeps the public web surface readable while preserving machine-friendly API and manifest routes.
    </footer>
  </main>
</body>
</html>
{{end}}
