{{define "layout"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{block "title" .}}Bountystash{{end}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/bountystash.css">
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <main class="shell" id="main">
    <nav class="topnav">
      <div class="topnav-inner">
        <a class="brand" href="/">bounty<span>stash</span></a>
        <ul class="nav-links">
          <li><a href="/"{{if eq .NavActive "home"}} aria-current="page"{{end}}>Home</a></li>
          <li><a href="/examples/auth-loop"{{if eq .NavActive "examples"}} aria-current="page"{{end}}>Examples</a></li>
          <li><a href="/review"{{if eq .NavActive "review"}} aria-current="page"{{end}}>Review</a></li>
          <li><a href="/history"{{if eq .NavActive "history"}} aria-current="page"{{end}}>History</a></li>
          <li><a href="/.well-known/bountystash-manifest">API</a></li>
        </ul>
      </div>
    </nav>
    {{block "content" .}}{{end}}
    <footer class="footer">
      server-rendered • immutable • engineering grid
    </footer>
  </main>
</body>
</html>
{{end}}
