{{define "title"}}History | Bountystash{{end}}

{{define "content"}}
<section class="panel">
  <div class="hero" style="margin-bottom:0.5rem;">
    <span class="kicker">Event ledger</span>
    {{if .WorkID}}
    <h1>Work history</h1>
    <p style="color:var(--text-secondary); margin:0;">
      <span class="mono">{{.WorkID}}</span>
      {{if .WorkTitle}}· {{.WorkTitle}}{{end}}
    </p>
    {{else}}
    <h1>Recent activity</h1>
    <p style="color:var(--text-secondary); margin:0;">System-wide ledger of recent backend events</p>
    {{end}}
  </div>
</section>

{{if .Entries}}
<div class="grid">
  {{range .Entries}}
  <article class="packet">
    <div class="hash">{{.DisplayType}}</div>
    <div class="date">{{.Timestamp.Format "2006-01-02 15:04 MST"}}</div>
    <h3>{{if .Summary}}{{.Summary}}{{else}}{{.DisplayType}}{{end}}</h3>
    {{if .Details}}
    <ul style="margin:0 0 0.75rem; padding-left:1.25rem; color:var(--text-secondary); font-size:0.875rem;">
      {{range .Details}}<li>{{.}}</li>{{end}}
    </ul>
    {{end}}
    {{if .WorkItemID}}
    <p style="margin:0; font-size:0.875rem;">
      Work: <a href="/work/{{.WorkItemID}}" class="action mono">{{.WorkItemID}}</a>
    </p>
    {{end}}
  </article>
  {{end}}
</div>
{{else}}
<section class="panel empty-state">
  <p>No history yet.</p>
</section>
{{end}}
{{end}}
