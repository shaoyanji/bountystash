{{define "title"}}History | Bountystash{{end}}

{{define "content"}}
<section class="panel">
  <div class="hero">
    <span class="kicker">Event ledger</span>
    {{if .WorkID}}
    <h1>Work history</h1>
    <p class="hint">Work item ID: {{.WorkID}}</p>
    {{if .WorkTitle}}
    <p class="hint">Title: {{.WorkTitle}}</p>
    {{end}}
    {{else}}
    <h1>Recent activity</h1>
    <p class="hint">System-wide ledger of recent backend events</p>
    {{end}}
  </div>
  {{if .Entries}}
  <table class="queue">
    <thead>
      <tr>
        <th>Timestamp</th>
        <th>Event</th>
        <th>Details</th>
      </tr>
    </thead>
    <tbody>
      {{range .Entries}}
      <tr>
        <td>{{.Timestamp.Format "2006-01-02 15:04 MST"}}</td>
        <td>{{.DisplayType}}</td>
        <td>
          <strong>{{if .Summary}}{{.Summary}}{{else}}—{{end}}</strong>
          {{if .Details}}
          <ul>
            {{range .Details}}
            <li>{{.}}</li>
            {{end}}
          </ul>
          {{end}}
        </td>
      </tr>
      {{end}}
    </tbody>
  </table>
  {{else}}
  <p class="hint">No recent events found.</p>
  {{end}}
</section>
{{end}}
