{{define "title"}}Example {{.Slug}} | Bountystash{{end}}

{{define "content"}}
<section class="hero panel">
  <h1>{{.Packet.Title}}</h1>
  <p>Seeded example packet <code>{{.Slug}}</code> for deterministic shape and UI preview.</p>
</section>

<section class="panel">
  <h2>Example Metadata</h2>
  <div class="meta-grid">
    <div class="meta-cell"><strong>Slug</strong>{{.Slug}}</div>
    <div class="meta-cell"><strong>Kind</strong>{{.Packet.Kind}}</div>
    <div class="meta-cell"><strong>Visibility</strong>{{.Packet.Visibility}}</div>
    <div class="meta-cell"><strong>Reward Model</strong>{{if .Packet.RewardModel}}{{.Packet.RewardModel}}{{else}}Not specified{{end}}</div>
  </div>
</section>

{{template "work_packet_sections" .Packet}}
{{end}}
