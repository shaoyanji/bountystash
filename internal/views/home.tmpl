{{define "title"}}Bountystash | Structured Technical Intake{{end}}

{{define "content"}}
<section class="hero panel">
  <span class="kicker">v0.2.0 public web</span>
  <h1>Turn messy technical asks into reviewable, traceable work items.</h1>
  <p>Bountystash is a thin server-rendered workflow that captures intake, normalizes the packet, and preserves a durable event trail your team can audit across browser, terminal, and agent-friendly surfaces.</p>
  <div class="cta-row">
    <a class="button-link" href="#intake">Create a work item</a>
    <a class="text-link" href="/examples/auth-loop">Browse examples</a>
    <a class="text-link" href="/history">See recent activity</a>
  </div>
</section>

<section class="panel">
  <h2>Use It Your Way</h2>
  <div class="grid">
    <article class="card">
      <h3>Browser Flow</h3>
      <p>Use the web UI to submit intake, inspect work item details, and follow history without leaving human-readable pages.</p>
      <p><a class="text-link" href="#intake">Start from intake</a></p>
    </article>
    <article class="card">
      <h3>curl and Agents</h3>
      <p>Use manifest and JSON routes to explore examples, queue state, and persisted packets from scripts or automation.</p>
      <p><a class="text-link" href="/.well-known/bountystash-manifest">Open manifest</a></p>
    </article>
    <article class="card">
      <h3>TUI / Text</h3>
      <p>Human-facing routes support <code>?format=md</code> and <code>?format=text</code> so terminal tools stay first-class.</p>
      <p><a class="text-link" href="/?format=text">Open text view</a></p>
    </article>
  </div>
</section>

<section class="panel">
  <h2>How It Works</h2>
  <p>Intake and review remain simple, while the backend records each key step as append-only events.</p>
  <div class="step-grid">
    <div class="step">
      <strong>1. Capture</strong>
      <p>Submit rough scope, deliverables, and acceptance criteria.</p>
    </div>
    <div class="step">
      <strong>2. Normalize</strong>
      <p>Shape the ask into a consistent packet and enforce visibility rules.</p>
    </div>
    <div class="step">
      <strong>3. Persist</strong>
      <p>Store immutable work versions with exact and quotient hashes.</p>
    </div>
    <div class="step">
      <strong>4. Review</strong>
      <p>Use queue and history views to inspect and trace operational flow.</p>
    </div>
  </div>
</section>

{{if .Errors}}
<section class="panel error-panel">
  <h2>Submission Error</h2>
  <ul>
    {{with index .Errors "title"}}<li>{{.}}</li>{{end}}
    {{with index .Errors "kind"}}<li>{{.}}</li>{{end}}
    {{with index .Errors "visibility"}}<li>{{.}}</li>{{end}}
  </ul>
</section>
{{end}}

<section class="panel">
  <h2>Featured Examples</h2>
  <div class="grid">
    {{range .FeaturedExamples}}
    <article class="card">
      <div class="chip-row">
        <span class="chip">{{.Packet.Kind}}</span>
        <span class="chip">{{.Packet.Visibility}}</span>
        <span class="chip">{{.Slug}}</span>
      </div>
      <h3><a href="/examples/{{.Slug}}">{{.Packet.Title}}</a></h3>
      {{if .Packet.Scope}}
      <p>{{index .Packet.Scope 0}}</p>
      {{else}}
      <p>No scope notes provided.</p>
      {{end}}
      <p class="hint">Reward model: {{if .Packet.RewardModel}}{{.Packet.RewardModel}}{{else}}Not specified{{end}}</p>
    </article>
    {{end}}
  </div>
</section>

<section class="panel">
  <h2>Recent Activity</h2>
  <p>System-wide timeline preview from the append-only backend events ledger.</p>
  {{if .RecentEntries}}
  <ul class="activity-list">
    {{range .RecentEntries}}
    <li class="activity-item">
      <div class="activity-head">
        <strong>{{if .Summary}}{{.Summary}}{{else}}{{.DisplayType}}{{end}}</strong>
        <time>{{.Timestamp.Format "2006-01-02 15:04 MST"}}</time>
      </div>
      <p>
        {{if .WorkItemID}}Work <a class="text-link" href="/work/{{.WorkItemID}}">{{.WorkItemID}}</a>{{else}}System event{{end}}
        {{if .Details}} · {{index .Details 0}}{{end}}
      </p>
    </li>
    {{end}}
  </ul>
  {{else if .RecentError}}
  <p class="hint">{{.RecentError}}</p>
  {{else}}
  <p class="hint">No recent activity yet.</p>
  {{end}}
  <p class="hint"><a class="text-link" href="/history">Open full history</a> · <a class="text-link" href="/api/events/recent">View JSON endpoint</a></p>
</section>

<section id="intake" class="panel">
  <h2>Intake Form</h2>
  <p>Use this form to create a new draft work item. For <code>private_security</code>, visibility is enforced as <code>private</code>.</p>
  <form method="post" action="/draft" class="intake-form">
    <label>
      Title
      <input type="text" name="title" placeholder="Short task title" required value="{{.Input.Title}}">
    </label>

    <div class="grid">
      <label>
        Kind
        <select name="kind" required>
          <option value="bounty" {{if eq .Input.Kind "bounty"}}selected{{end}}>bounty</option>
          <option value="rfq" {{if eq .Input.Kind "rfq"}}selected{{end}}>rfq</option>
          <option value="rfp" {{if eq .Input.Kind "rfp"}}selected{{end}}>rfp</option>
          <option value="private_security" {{if eq .Input.Kind "private_security"}}selected{{end}}>private_security</option>
        </select>
      </label>

      <label>
        Visibility
        <select name="visibility" required>
          <option value="draft" {{if or (eq .Input.Visibility "") (eq .Input.Visibility "draft")}}selected{{end}}>draft</option>
          <option value="private" {{if eq .Input.Visibility "private"}}selected{{end}}>private</option>
          <option value="public" {{if eq .Input.Visibility "public"}}selected{{end}}>public</option>
          <option value="archived" {{if eq .Input.Visibility "archived"}}selected{{end}}>archived</option>
        </select>
      </label>
    </div>

    <label>
      Scope
      <textarea name="scope" placeholder="One line per scope item">{{.Input.Scope}}</textarea>
    </label>

    <label>
      Deliverables
      <textarea name="deliverables" placeholder="One line per deliverable">{{.Input.Deliverables}}</textarea>
    </label>

    <label>
      Acceptance Criteria
      <textarea name="acceptance_criteria" placeholder="One line per acceptance criterion">{{.Input.AcceptanceCriteria}}</textarea>
    </label>

    <label>
      Reward / Quote Model
      <input type="text" name="reward_model" placeholder="Fixed bounty, quoted engagement, etc." value="{{.Input.RewardModel}}">
    </label>

    <p class="hint">Safety rule: <code>private_security</code> packets are persisted as <code>private</code> visibility.</p>
    <button type="submit">Create Work Item</button>
  </form>
</section>

<section class="panel">
  <h2>Route Guide</h2>
  <p>Public routes: <code>/</code>, <code>/examples/{slug}</code>, <code>/review</code>, <code>/history</code>, <code>/work/{id}</code>.</p>
  <p>Machine-friendly surfaces stay adjacent: <a class="text-link" href="/.well-known/bountystash-manifest">manifest</a> and <a class="text-link" href="/api/examples">/api/*</a>.</p>
  <ul class="inline-list">
    <li><a href="/examples/auth-loop">auth-loop</a></li>
    <li><a href="/examples/webhook-rfq">webhook-rfq</a></li>
    <li><a href="/examples/pipeline-rfp">pipeline-rfp</a></li>
  </ul>
</section>
{{end}}
