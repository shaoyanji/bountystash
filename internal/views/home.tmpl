{{define "title"}}Bountystash Intake{{end}}

{{define "content"}}
<section class="hero">
  <h1>Bountystash</h1>
  <p>Messy intake becomes a deterministic, immutable packet with persisted provenance hashes.</p>
</section>

{{if .Errors}}
<section class="panel error-panel">
  <h2>Submission Error</h2>
  <ul>
    {{with index .Errors "title"}}<li>{{.}}</li>{{end}}
    {{with index .Errors "kind"}}<li>{{.}}</li>{{end}}
    {{with index .Errors "visibility"}}<li>{{.}}</li>{{end}}
  </ul>
</section>
{{end}}

<section class="panel">
  <h2>Work Item Intake</h2>
  <form method="post" action="/draft" class="intake-form">
    <label>
      Title
      <input type="text" name="title" placeholder="Short task title" required value="{{.Input.Title}}">
    </label>

    <div class="grid">
      <label>
        Kind
        <select name="kind" required>
          <option value="bounty" {{if eq .Input.Kind "bounty"}}selected{{end}}>bounty</option>
          <option value="rfq" {{if eq .Input.Kind "rfq"}}selected{{end}}>rfq</option>
          <option value="rfp" {{if eq .Input.Kind "rfp"}}selected{{end}}>rfp</option>
          <option value="private_security" {{if eq .Input.Kind "private_security"}}selected{{end}}>private_security</option>
        </select>
      </label>

      <label>
        Visibility
        <select name="visibility" required>
          <option value="draft" {{if or (eq .Input.Visibility "") (eq .Input.Visibility "draft")}}selected{{end}}>draft</option>
          <option value="private" {{if eq .Input.Visibility "private"}}selected{{end}}>private</option>
          <option value="public" {{if eq .Input.Visibility "public"}}selected{{end}}>public</option>
          <option value="archived" {{if eq .Input.Visibility "archived"}}selected{{end}}>archived</option>
        </select>
      </label>
    </div>

    <label>
      Scope
      <textarea name="scope" placeholder="One line per scope item">{{.Input.Scope}}</textarea>
    </label>

    <label>
      Deliverables
      <textarea name="deliverables" placeholder="One line per deliverable">{{.Input.Deliverables}}</textarea>
    </label>

    <label>
      Acceptance Criteria
      <textarea name="acceptance_criteria" placeholder="One line per acceptance criterion">{{.Input.AcceptanceCriteria}}</textarea>
    </label>

    <label>
      Reward / Quote Model
      <input type="text" name="reward_model" placeholder="Fixed bounty, quoted engagement, etc." value="{{.Input.RewardModel}}">
    </label>

    <p class="hint">Safety rule: <code>private_security</code> packets are persisted as <code>private</code> visibility.</p>
    <button type="submit">Create Work Item</button>
  </form>
</section>

<section class="panel">
  <h2>Seeded Examples</h2>
  <ul class="inline-list">
    <li><a href="/examples/auth-loop">auth-loop</a></li>
    <li><a href="/examples/webhook-rfq">webhook-rfq</a></li>
    <li><a href="/examples/pipeline-rfp">pipeline-rfp</a></li>
  </ul>
</section>
{{end}}
