{{define "title"}}Bountystash | Structured Technical Intake{{end}}

{{define "content"}}
<section class="hero panel">
  <h1>Deterministic<span class="accent-dot">.</span><br>Immutable packets<span class="accent-dot">.</span></h1>
  <p>Turn messy technical asks into structured, reviewable work items across browser, terminal, and agent-friendly surfaces.</p>
  <div class="cta-row">
    <a class="btn btn-primary" href="#intake">New packet ▶</a>
    <a class="btn btn-secondary" href="/examples/auth-loop">Browse examples</a>
  </div>
</section>

{{if .Errors}}
<section class="panel error-panel">
  <h2>Submission Error</h2>
  <ul>
    {{with index .Errors "title"}}<li>{{.}}</li>{{end}}
    {{with index .Errors "kind"}}<li>{{.}}</li>{{end}}
    {{with index .Errors "visibility"}}<li>{{.}}</li>{{end}}
  </ul>
</section>
{{end}}

<div class="section-header">Live packets • Grid active</div>
{{if .FeaturedExamples}}
<section class="grid">
  {{range .FeaturedExamples}}
  <article class="packet">
    <div class="hash">{{.Slug}}</div>
    <div class="cta-row" style="margin-bottom:0.5rem;">
      <span class="kind-badge {{.Packet.Kind}}">{{.Packet.Kind}}</span>
      <span class="kind-badge {{.Packet.Visibility}}">{{.Packet.Visibility}}</span>
    </div>
    <h3><a href="/examples/{{.Slug}}">{{.Packet.Title}}</a></h3>
    {{if .Packet.Scope}}
    <p>{{index .Packet.Scope 0}}</p>
    {{else}}
    <p>No scope notes provided.</p>
    {{end}}
    <a href="/examples/{{.Slug}}" class="action">Open sheet →</a>
  </article>
  {{end}}
</section>
{{else}}
<section class="panel empty-state">
  <p>No featured packets yet.</p>
  <a href="/work" class="btn btn-primary">Create the first packet</a>
</section>
{{end}}

{{if .RecentEntries}}
<div class="section-header">Recent activity</div>
<section class="panel">
  <ul class="activity-list">
    {{range .RecentEntries}}
    <li class="activity-item">
      <div class="activity-head">
        <strong>{{if .Summary}}{{.Summary}}{{else}}{{.DisplayType}}{{end}}</strong>
        <time>{{.Timestamp.Format "2006-01-02 15:04 MST"}}</time>
      </div>
      <p>
        {{if .WorkItemID}}Work <a href="/work/{{.WorkItemID}}" class="action">{{.WorkItemID}}</a>{{else}}System event{{end}}
        {{if .Details}} · {{index .Details 0}}{{end}}
      </p>
    </li>
    {{end}}
  </ul>
  <p style="margin-top:0.75rem; margin-bottom:0;"><a href="/history" class="action">Full history →</a></p>
</section>
{{else if .RecentError}}
<div class="section-header">Recent activity</div>
<section class="panel">
  <p style="color:var(--text-muted); margin:0;">{{.RecentError}}</p>
</section>
{{end}}

<section id="intake" class="panel">
  <div class="section-header" style="margin-top:0;">Create work item</div>
  <form method="post" action="/draft" class="intake-form">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" placeholder="Short task title" required value="{{.Input.Title}}">

    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.75rem;">
      <div>
        <label for="kind">Kind</label>
        <select id="kind" name="kind" required>
          <option value="bounty" {{if eq .Input.Kind "bounty"}}selected{{end}}>bounty</option>
          <option value="rfq" {{if eq .Input.Kind "rfq"}}selected{{end}}>rfq</option>
          <option value="rfp" {{if eq .Input.Kind "rfp"}}selected{{end}}>rfp</option>
          <option value="private_security" {{if eq .Input.Kind "private_security"}}selected{{end}}>private_security</option>
        </select>
      </div>

      <div>
        <label for="visibility">Visibility</label>
        <select id="visibility" name="visibility" required>
          <option value="draft" {{if or (eq .Input.Visibility "") (eq .Input.Visibility "draft")}}selected{{end}}>draft</option>
          <option value="private" {{if eq .Input.Visibility "private"}}selected{{end}}>private</option>
          <option value="public" {{if eq .Input.Visibility "public"}}selected{{end}}>public</option>
          <option value="archived" {{if eq .Input.Visibility "archived"}}selected{{end}}>archived</option>
        </select>
      </div>
    </div>

    <label for="scope">Scope</label>
    <textarea id="scope" name="scope" placeholder="One line per scope item">{{.Input.Scope}}</textarea>

    <label for="deliverables">Deliverables</label>
    <textarea id="deliverables" name="deliverables" placeholder="One line per deliverable">{{.Input.Deliverables}}</textarea>

    <label for="acceptance_criteria">Acceptance Criteria</label>
    <textarea id="acceptance_criteria" name="acceptance_criteria" placeholder="One line per acceptance criterion">{{.Input.AcceptanceCriteria}}</textarea>

    <label for="reward_model">Reward / Quote Model</label>
    <input type="text" id="reward_model" name="reward_model" placeholder="Fixed bounty, quoted engagement, etc." value="{{.Input.RewardModel}}">

    <p style="color:var(--text-muted); font-size:0.875rem; margin:0;">Safety rule: <code>private_security</code> packets are persisted as <code>private</code> visibility.</p>
    <button type="submit">Create Work Item</button>
  </form>
</section>
{{end}}
